// API para obtener imágenes de Unsplash
app.get('/api/unsplash', async (c) => {
  încearcă {
    const query = c.req.query('q') || 'naturaleza';
    const apiKey = Bun.env.UNSPLASH_API_KEY;
    
    dacă (!apiKey) {
      devuelve c.json({url: 'https://via.placeholder.com/1920x1080?text=Fondo' });
    }
    
    respuesta constante = esperar buscar(
      `https://api.unsplash.com/search/photos?query=${query}&per_page=1&client_id=${apiKey}`
    );
    
    datos constantes = esperar respuesta.json();
    
    if (data.results && data.results.length > 0) {
      devolver c.json({
        url: data.results[0].urls.regular,
        fotógrafo: data.results[0].user.name,
        enlace: data.results[0].links.html
      });
    }
    
    devuelve c.json({url: 'https://via.placeholder.com/1920x1080?text=Fondo' });
  } captar (error) {
    devuelve c.json({url: 'https://via.placeholder.com/1920x1080?text=Fondo' });
  }
});

